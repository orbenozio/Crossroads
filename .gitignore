# Claude / Agents hub - machine-specific junctions, not part of the project
.claude/

# Agent/dev working artifacts - bridge screenshots and scratch captures, not project source
.utmp/
_screens/
UnityAgentBridge/Screenshots/

# OS / editor
Thumbs.db
.DS_Store
*.swp
.vscode/

# Net working-time log (auto-measured via global hooks; also self-ignores)
.timelog/

# Logs / temp
*.log
tmp/
temp/
# --- Unity ---
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta files only ignored when their asset is also ignored
!/[Aa]ssets/**/*.meta

# Unity build artifacts
*.unitypackage
*.apk
*.aab
*.app
crashlytics-build.properties
sysinfo.txt

